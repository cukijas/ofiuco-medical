# Ofiuco Medical API - Environment Variables

# ──────────────────────────────────────────────
# Database (used by docker-compose and backend)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ofiuco_medical
POSTGRES_DB=ofiuco_medical
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ──────────────────────────────────────────────
# JWT Authentication
# ──────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────────
# Azure OneDrive Integration (optional)
# ──────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
PUBLIC_URL=http://localhost:8000
DEBUG=true

# ──────────────────────────────────────────────
# Ports (docker-compose)
# ──────────────────────────────────────────────
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=80
